# Optional when the Web dashboard is deployed outside the API origin.
# Local Vite dev can leave both empty because /api is proxied and WebSocket uses localhost:8787.
VITE_API_BASE_URL=
VITE_WS_URL=

# Cloudflare Pages example:
# VITE_API_BASE_URL=https://your-api-domain.example.com
# VITE_WS_URL=wss://your-api-domain.example.com/ws

# The deployed dashboard also supports temporary runtime overrides:
# https://your-pages-domain/?api=https://your-api.trycloudflare.com
# https://your-pages-domain/?api=https://your-api.trycloudflare.com&ws=wss://your-api.trycloudflare.com/ws
