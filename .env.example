# Backend
API_PORT=8787
WEB_PORT=5173

# LLM mode: mock | doubao
AGENT_LLM_MODE=mock

# Volcengine Ark / Doubao
# Do not commit real keys. Put your real values in .env or .env.local.
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_ENDPOINT_ID=ep-xxxxxxxxxxxxxxxx-xxxxx
ARK_API_KEY=ark-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx-xxxxx

# Office adapter: mock | lark-cli
OFFICE_ADAPTER=mock
LARK_CLI_BIN=lark-cli
LARK_DEFAULT_CHAT_ID=
